{
  "manifest_version": 3,
  "name": "AgentTrace",
  "version": "0.1.0",
  "description": "Record browser actions. Export AI-resilient automation scripts.",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "extension/popup/popup.html",
    "default_icon": {
      "16": "extension/icons/icon-16.png",
      "48": "extension/icons/icon-48.png",
      "128": "extension/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "extension/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension/content/recorder.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "extension/icons/icon-16.png",
    "48": "extension/icons/icon-48.png",
    "128": "extension/icons/icon-128.png"
  }
}
